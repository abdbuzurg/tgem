# Backend environment template.
#
# NOTE on filename: this template is committed as `env.backend.example`
# (without the leading dot) because the working environment's safety
# settings deny writes to `./.env.*` paths. On the production server,
# COPY (not link) this to `.env.backend` at the repo root before running
# docker compose:
#
#     cp env.backend.example .env.backend
#     $EDITOR .env.backend
#
# `.env.backend` is what docker-compose.yml reads via env_file:. It is
# gitignored. This file (the example) is committed.
#
# Every variable without a default value is REQUIRED — the entrypoint
# fails fast if anything is missing, so docker-compose surfaces the
# misconfiguration in its restart loop.
#
# YAML quoting caveat: DB_PASSWORD, JWT_SECRET, DB_USERNAME, and DB_NAME
# are embedded into a double-quoted YAML scalar at startup. Do not use raw
# double quotes (") or backslashes (\) in those values; the entrypoint
# will refuse to start if it finds them.

# ---------------------------------------------------------------------------
# HTTP listener
# ---------------------------------------------------------------------------

# Bind address inside the container's network namespace. 0.0.0.0 is correct
# for Docker port mapping. Use 127.0.0.1 only if running on the host without
# Docker.
APP_HOST=0.0.0.0

# Port the backend listens on. Must match the docker-compose port mapping
# (default 5000). Leave at 5000 unless the migration runbook says otherwise.
APP_PORT=5000

# ---------------------------------------------------------------------------
# PostgreSQL (host-tier database — see MIGRATION/00-inspection.md)
# ---------------------------------------------------------------------------

# Host the backend connects to. From inside the container, the host machine
# is reachable as host.docker.internal (mapped via extra_hosts in
# docker-compose.yml).
DB_HOST=host.docker.internal

# Postgres port on the host.
DB_PORT=5432

# Database user. Production almost certainly uses something other than the
# committed legacy default of 'postgres'.
DB_USERNAME=REPLACE_ME

# Database password. Read from the live App_dev.yaml on the production
# server — it does not match the committed dev value 'password'.
DB_PASSWORD=REPLACE_ME

# Database name. Legacy uses 'tgem'; verify against the production file.
DB_NAME=tgem

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# JWT signing secret. MUST equal the value in production's existing
# App_dev.yaml — otherwise every logged-in user's session is invalidated at
# cutover and they're forced to re-login. The committed dev value
# 'q1w2e3r4t5y6' is NOT what production uses.
JWT_SECRET=REPLACE_ME

# ---------------------------------------------------------------------------
# Filesystem
# ---------------------------------------------------------------------------

# Legacy Files.Path config. Inside the container this resolves to /app/files,
# which is a named docker volume. Leave as-is unless you know the rewrite
# uses it differently.
FILES_PATH=./files

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------

# Permission enforcement mode for the rewrite's v2 permission middleware.
#   "0" -> log-only (mirrors legacy no-op behavior). Recommended at cutover.
#   any other value -> enforce; users without the matching grant get 403.
# Bump to "1" only after post-migration permission verification confirms
# that all production roles have the grants they need.
AUTH_PERMISSIONS_ENFORCE=0
